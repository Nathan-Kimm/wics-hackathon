{
  "manifest_version": 3,
  "name": "Spotify Chords",
  "version": "1.0",
  "description": "Shows chord progression for the current Spotify track.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "action": {
    "default_popup": "extension/authentication.html",
    "default_icon": {
      "16": "spotichrd.png",
      "48": "spotichrd.png",
      "128": "spotichrd.png"
    }
  }
}