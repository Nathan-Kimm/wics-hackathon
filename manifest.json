{
  "manifest_version": 3,
  "name": "Spotify Chords",
  "version": "1.0",
  "description": "Shows compatible chords for the current Spotify track.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://open.spotify.com/*"],
  "action": {
    "default_popup": "extension/authentication.html"
  },
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["extension/content.js"]
    }
  ]
}